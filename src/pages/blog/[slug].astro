---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getReadingTime } from '../../utils/reading-time';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);
const readingTime = getReadingTime(post.body ?? '');

const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    post: p,
    shared: p.data.tags.filter((t: string) => post.data.tags.includes(t)).length,
  }))
  .filter((p) => p.shared > 0)
  .sort((a, b) => b.shared - a.shared || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map((p) => p.post);
---

<BaseLayout title={`${post.data.title} — Brooks Marshall`} description={post.data.description}>
  <article class="prose-article prose prose-invert max-w-none prose-headings:font-ui prose-headings:text-accent-500 prose-a:text-accent-500 prose-a:hover:text-accent-400">
    <header class="mb-8 not-prose">
      <h1 class="font-ui text-3xl font-bold tracking-tight text-accent-500">{post.data.title}</h1>
      <div class="flex items-center gap-3 text-sm text-base-300">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{readingTime}</span>
      </div>
    </header>
    <Content />
  </article>

  {relatedPosts.length > 0 && (
    <aside class="mt-16 pt-8 border-t border-base-500">
      <h2 class="font-ui text-xl font-semibold text-accent-500 mb-4">Related Posts</h2>
      <div class="space-y-2">
        {relatedPosts.map((related) => (
          <PostCard
            title={related.data.title}
            description={related.data.description}
            pubDate={related.data.pubDate}
            href={`${base}/blog/${related.id}`}
            readingTime={getReadingTime(related.body ?? '')}
          />
        ))}
      </div>
    </aside>
  )}
</BaseLayout>
