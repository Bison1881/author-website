---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const books = await getCollection('books');
---

<BaseLayout title="Books — Brooks Marshall">
  <PageHeader title="Books" subtitle="Novels from the Steadfast Universe." />
  {books.length === 0 ? (
    <p class="text-base-300 italic">Books coming soon.</p>
  ) : (
    <div class="space-y-8">
      {books.map((book) => (
        <div class="p-4 -mx-4 rounded-lg border border-base-500">
          <h2 class="font-ui text-xl font-semibold text-accent-500">{book.data.title}</h2>
          <p class="text-sm text-base-300 mt-1">
            Status: {book.data.status.charAt(0).toUpperCase() + book.data.status.slice(1)}
            {book.data.releaseDate && (
              <span> · {book.data.releaseDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
            )}
          </p>
          <p class="mt-3 leading-relaxed">{book.data.description}</p>
          {book.data.buyLinks.length > 0 && (
            <div class="mt-4 flex gap-3">
              {book.data.buyLinks.map((link) => (
                <a
                  href={link.url}
                  class="text-sm font-ui font-semibold text-accent-500 hover:text-accent-400 underline transition-colors"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {link.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  )}
</BaseLayout>
