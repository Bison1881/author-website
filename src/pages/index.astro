---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getReadingTime } from '../utils/reading-time';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Brooks Marshall — Author">
  <section class="space-y-8">
    <div>
      <h1 class="font-ui text-4xl font-bold tracking-tight text-accent-500">Brooks Marshall</h1>
      <p class="mt-1 font-ui text-lg text-base-300">Author of the Steadfast Universe</p>
    </div>
    <p class="text-lg leading-relaxed">
      Welcome. This is where I share development logs, short fiction, and updates
      on the journey toward publication — stories of faith, resilience, and the
      cost of standing firm.
    </p>
    <div class="pt-4">
      <h2 class="font-ui text-xl font-semibold text-accent-500 mb-4">Latest Posts</h2>
      {posts.length === 0 ? (
        <p class="text-base-300 italic">Posts coming soon.</p>
      ) : (
        <div class="space-y-2">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              href={`${base}/blog/${post.id}`}
              readingTime={getReadingTime(post.body ?? '')}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
