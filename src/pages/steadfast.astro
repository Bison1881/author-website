---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const books = await getCollection('books');
const stories = (await getCollection('stories', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="The Steadfast Universe — Brooks Marshall">
  <PageHeader title="The Steadfast Universe" subtitle="Where the West meets the modern world — and faith is tested." />
  <div class="space-y-10 leading-relaxed">
    <section>
      <p>
        The Steadfast Universe is a world of classic western grit and modern-day suspense,
        told through the lens of a Christian worldview. It's a place where faith costs something,
        where standing firm means standing alone, and where the line between right and wrong
        cuts through every human heart.
      </p>
      <p class="mt-4 text-base-300 italic">More details about the world, its history, and its characters are coming soon.</p>
    </section>

    {books.length > 0 && (
      <section>
        <h2 class="font-ui text-xl font-semibold text-accent-500 mb-4">Books</h2>
        <ul class="space-y-2">
          {books.map((book) => (
            <li>
              <span class="font-semibold">{book.data.title}</span>
              <span class="text-base-300"> — {book.data.status}</span>
            </li>
          ))}
        </ul>
        <a href={`${base}/books`} class="inline-block mt-3 text-sm font-ui text-accent-500 hover:text-accent-400 underline transition-colors">
          View all books →
        </a>
      </section>
    )}

    {stories.length > 0 && (
      <section>
        <h2 class="font-ui text-xl font-semibold text-accent-500 mb-4">Short Fiction</h2>
        <ul class="space-y-2">
          {stories.map((story) => (
            <li>
              <a href={`${base}/stories/${story.id}`} class="text-accent-500 hover:text-accent-400 underline transition-colors">
                {story.data.title}
              </a>
              {story.data.series && <span class="text-base-300"> — {story.data.series}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>
