---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const stories = await getCollection('stories', ({ data }) => !data.draft);
  return stories.map((story) => ({
    params: { slug: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);
---

<BaseLayout title={`${story.data.title} — Brooks Marshall`} description={story.data.description}>
  <article class="prose-article prose prose-invert max-w-none prose-headings:font-ui prose-headings:text-accent-500 prose-a:text-accent-500 prose-a:hover:text-accent-400">
    <header class="mb-8 not-prose">
      <h1 class="font-ui text-3xl font-bold tracking-tight text-accent-500">{story.data.title}</h1>
      {story.data.series && (
        <p class="text-sm text-base-300 mt-1">{story.data.series}</p>
      )}
      <time class="text-sm text-base-300" datetime={story.data.pubDate.toISOString()}>
        {story.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <Content />
  </article>
</BaseLayout>
