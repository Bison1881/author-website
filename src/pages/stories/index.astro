---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PostCard from '../../components/PostCard.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const stories = (await getCollection('stories', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Stories — Brooks Marshall">
  <PageHeader title="Stories" subtitle="Short fiction from the Steadfast Universe and beyond." />
  {stories.length === 0 ? (
    <p class="text-base-300 italic">Stories coming soon.</p>
  ) : (
    <div class="space-y-2">
      {stories.map((story) => (
        <PostCard
          title={story.data.title}
          description={story.data.description}
          pubDate={story.data.pubDate}
          href={`${base}/stories/${story.id}`}
        />
      ))}
    </div>
  )}
</BaseLayout>
